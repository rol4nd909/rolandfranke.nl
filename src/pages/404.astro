---
import Heading from '@/components/ui/Heading.astro'
import Hero from '@/components/ui/Hero.astro'
import BaseLayout from '@layouts/BaseLayout.astro'
---

<BaseLayout
    title="Oeps page not found - Roland Franke"
    description="The page you are looking for is not found"
    showWebring={false}
>
    <Hero class="hero--large text-center" data-grid="fullbleed">
        <Heading tagName="h1" size="h1" class="hero__title" id="page-heading">
            <span>&#123;</span> 404 <span>&#125;</span>
        </Heading>
        <p class="hero__content">Oeps not found the page you're looking for</p>
    </Hero>
</BaseLayout>

<style>
    .hero__title {
        /* fix to align the title with text after it */
        margin-inline-start: -0.085ch;
        font-size: utopia.clamp(80, 260, 320, 1200);
        font-weight: var(--fw-semibold);

        view-transition-name: none;

        > span {
            font-family: var(--ff-serif);
            color: var(--color-primary-400);
        }
    }

    .hero__content {
        font-family: var(--ff-serif);
        font-size: utopia.clamp(18, 28);
    }
</style>
