---
import Dot from '@/components/ui/Dot.astro'
import Heading from '@/components/ui/Heading.astro'
import Hero from '@/components/ui/Hero.astro'
import BaseLayout from '@layouts/BaseLayout.astro'
---

<BaseLayout>
    <Hero class="hero--large" data-grid="fullbleed">
        <Heading tagName="h1" size="h1" class="hero__title" id="page-heading" tabindex="-1">
            roland<span aria-hidden="true">.</span>
        </Heading>
        <div class="hero__explain flex letter-spacing" aria-hidden="true">
            <span>[<span class="ff-serif">r<span class="underline">o</span>.land</span>]</span>
            <Dot size="large" />
            <b>frontend developer</b>
        </div>
        <p class="hero__content">
            <i>Roland</i> is a frontend developer with a passion for creative coding and a sharp focus
            on CSS, HTML, and accessibility. I thrive on building web experiences that are not only visually
            appealing but accessible and performant for everyone.
        </p>
    </Hero>
</BaseLayout>

<style>
    .hero__title {
        /* fix to align the title with text after it */
        font-size: utopia.clamp(80, 260, 320, 1200);
        font-weight: var(--fw-semibold);
        white-space: nowrap;

        view-transition-name: none;

        > span {
            color: var(--color-primary-400);
        }
    }

    .hero__explain {
        --letter-spacing: 3;

        font-size: utopia.clamp(20, 38);
    }

    .hero__content {
        font-size: utopia.clamp(18, 28);
    }
</style>
