---
import CustomLink from '@components/ui/CustomLink.astro'
import type { HTMLAttributes } from 'astro/types'

type Props = HTMLAttributes<'ul'> & {
    pathName: string
    className?: string
}

const { pathName, className, ...rest } = Astro.props
---

<ul class:list={['list', className]} {...rest}>
    <li>
        <CustomLink
            href="/frontend-stories/"
            aria-current={pathName.slice(1) === 'frontend-stories/' ? 'page' : undefined}
            >Frontend Stories</CustomLink
        >
    </li>
    <li>
        <CustomLink
            href="/about/"
            aria-current={pathName.slice(1) === 'about/' ? 'page' : undefined}>About</CustomLink
        >
    </li>
</ul>

<style>
    ul {
        display: flex;
        align-items: center;
        justify-items: center;
        text-align: center;
        gap: 1.5rem;
        margin: 0.5rem;
        padding: 0;

        @media (--small-nav) {
            display: grid;
            margin: 0;
            font-family: var(--ff-serif);
            font-size: var(--fs-1);
            font-weight: var(--fw-semibold);
        }
    }
</style>
