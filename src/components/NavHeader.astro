---
import Logo from '@/icons/logo.svg'
import DarkLightToggle from '@components/DarkLightToggle.astro'
import Link from '@components/ui/Link.astro'

const { pathname } = Astro.url
---

<header>
    <a href="/" aria-current={pathname.slice(1) === '' ? 'page' : undefined}>
        <Logo width="48" height="48" aria-label="Logo: RF (Roland Franke)" fill="currentColor" />
        <span class="sr-only"> - Home page</span>
    </a>

    <nav class="nav" aria-label="Primary navigation">
        <ul class="menu">
            <li>
                <Link
                    as="a"
                    href="/frontend-stories"
                    aria-current={pathname.slice(1) === 'frontend-stories' ? 'page' : undefined}
                    >Frontend Stories</Link
                >
            </li>
        </ul>
    </nav>

    <div>
        <DarkLightToggle />
    </div>
</header>

<style>
    :root {
        --header-height: 6rem;
    }

    header {
        position: absolute;
        inset: 0 0 auto;
        z-index: 1;

        display: flex;
        align-items: center;
        align-self: flex-start;
        justify-content: space-between;
        gap: utopia.clamp(16, 24);

        padding-block: 1.5rem;
        /* The 960 value is the minumun constrain value */
        padding-inline: utopia.clamp(24, 72, 960);

        div {
            min-inline-size: 3rem;
        }
    }

    a:not(.btn) {
        display: inline-flex;
    }

    svg {
        color: var(--color-primary-400);
        background-color: var(--color-neutral-100);
        align-self: center;
    }

    .menu {
        display: flex;
        gap: utopia.clamp(16, 24);
        padding-inline: 0;
    }
</style>
